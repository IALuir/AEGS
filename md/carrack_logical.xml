<?xml version="1.0" encoding="utf-8"?>
<mdscript name="carrack_logical" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
	<cues>
		<cue name="carrack_logical_start" instantiate="true">
			<conditions>
                    <event_player_changed_activity/>
			     <check_value value="player.ship.macro == macro.carrack_macro"/>
               </conditions>
			<actions>
				<do_if value="event.param == activity.scan_longrange">
					<trigger_animation object="player.ship" group="'scan'" trigger="activate" />
					<add_equipment_mods object="player.ship">
                        <ship ware="ware.mod_carrack_scan_system_on"/>
                    </add_equipment_mods>
				</do_if>
				<do_else>
					<trigger_animation object="player.ship" group="'scan'" trigger="deactivate" />
					<add_equipment_mods object="player.ship">
                        <ship ware="ware.mod_carrack_scan_system_off"/>
                    </add_equipment_mods>
				</do_else>
			</actions>
		</cue>

		<cue name="Player_carrack_c8_Build_Finished" instantiate="true">
               <conditions>
                    <event_player_build_finished/>
                    <check_value value="@event.param3.buildobject.macro.ismacro.{macro.carrack_macro} or @event.param3.macro.ismacro.{macro.carrack_macro}"/>
               </conditions>
               <actions>
                    <set_value name="$Ship" exact="@event.param3.buildobject"/>

                    <create_ship name="$c8x" dock="$Ship" macro="macro.c8x_macro">
                         <owner exact="faction.player"/>
                         <pilot>
                              <select tags="tag.pilot" race="race.terran"/>
                              <skills>
                                   <skill type="piloting"    exact="2"/>
                              </skills>
                         </pilot>
                    </create_ship>
               </actions>
          </cue>

          <cue name="carrack_logical_dock_01" instantiate="true">
			<conditions>
                    <check_any>
					<event_game_started />
					<event_game_loaded />
				</check_any>
               </conditions>
			<actions>
				<create_group groupname="$Object_carrack"/>
			</actions>
               <cues>
                    <cue name="carrack_logical_dock_02" instantiate="true" checkinterval="3s">
                         <actions>
                              <find_ship name="$Object" macro="macro.carrack_macro"  multiple="true" />
                              <do_for_each name="$ship" in="$Object">
                                   <add_to_group groupname="$Object_carrack" object="$ship"/>
				          </do_for_each>
                         </actions>
                    </cue>

                    <cue name="carrack_logical_dock_03" instantiate="true" checkinterval="5s">
                         <actions>
                              <clear_group group="$Object_carrack"/>
                         </actions>
                    </cue>

                    <cue name="carrack_logical_dock_04" instantiate="true">
                         <conditions>
                              <event_object_dock_assigned_at group="$Object_carrack"/>
                              <check_value value="not event.param2.macro.ismacro.[macro.c8x_macro]"/>
                         </conditions>
                         <actions>
                              <remove_docking_request ship="event.param2" container="event.param" immediate="true"/>
                              <do_for_each name="$order" in="event.param2.orders">
                                   <do_if value="$order.id == 'DockAt'">
                                        <cancel_order order="$order" />
                                   </do_if>
                        	     </do_for_each>
                         </actions>
                    </cue>
               </cues>
		</cue>
	</cues>
</mdscript>