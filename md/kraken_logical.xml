<?xml version="1.0" encoding="utf-8"?>
<mdscript name="kraken_logical" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
	<cues>

          <cue name="add_ore" instantiate="true" checkinterval="10s">	
			<actions>
			     <find_ship name="$Ships" macro="macro.ship_drak_kraken_macro"  multiple="true" />
                    <do_all exact="$Ships.count" counter="$i">
                         <add_tradeware object="$Ships.{$i}" ware="ware.ore" allowbuy="true" allowsell="false" />
                         <add_tradeware object="$Ships.{$i}" ware="ware.refinedmetals" allowbuy="false" allowsell="true" />
                         <set_tradeoffers_enabled object="$Ships.{$i}" enabled="true"/>
                         <set_value name="$ore" exact="$Ships.{$i}.cargo.{ware.ore}.count"/>
                         <do_if value="$ore ge 60" >
                              <remove_cargo object="$Ships.{$i}" ware="ware.ore" exact="160"/>
                              <add_cargo object="$Ships.{$i}" ware="ware.refinedmetals" exact="40"/>
                         </do_if>
                    </do_all>
			</actions>
		</cue>

          <cue name="kraken_logical_dock_01" instantiate="true">
			<conditions>
                    <check_any>
					<event_game_started />
					<event_game_loaded />
				</check_any>
               </conditions>
			<actions>
				<create_group groupname="$Object_kraken"/>
                    <set_value name="$hasship_s" exact="0"/>
                    <set_value name="$hasship_m" exact="0"/>
			</actions>
               <cues>
                    <cue name="kraken_logical_dock_02" instantiate="true" checkinterval="3s">
                         <actions>
                              <set_value name="$hasship_s" exact="0"/>
                              <set_value name="$hasship_m" exact="0"/>
                              <find_ship name="$Object" macro="macro.ship_drak_kraken_macro"  multiple="true" />
                              <do_for_each name="$ship" in="$Object">
                                   <add_to_group groupname="$Object_kraken" object="$ship"/>
                                   <find_dockingbay name="$dockingbays_k" object="$ship" macro="[macro.kraken_airporta_macro,macro.kraken_airportb_macro,macro.dockingbay_aegs_bengal_m_macro]" multiple="true"/>
                                   <do_all exact="$dockingbays_k.count" counter="$i">
								<do_if value="$dockingbays_k.{$i}.assignedship and $dockingbays_k.{$i}.macro.ismacro.[macro.kraken_airporta_macro,macro.kraken_airportb_macro]">
									<set_value name="$hasship_s" exact="1"/>
								</do_if>
                                        <do_elseif value="$dockingbays_k.{$i}.assignedship and $dockingbays_k.{$i}.macro.ismacro.[macro.dockingbay_aegs_bengal_m_macro]">
                                             <set_value name="$hasship_m" exact="1"/>
                                        </do_elseif>
							</do_all>
				          </do_for_each>
                         </actions>
                    </cue>

                    <cue name="kraken_logical_dock_03" instantiate="true" checkinterval="5s">
                         <actions>
                              <clear_group group="$Object_kraken"/>
                         </actions>
                    </cue>

                    <cue name="kraken_logical_dock_04" instantiate="true">
                         <conditions>
                              <event_object_dock_assigned_at group="$Object_kraken"/>
                              <check_value value="event.param2.isclass.[class.ship_m]"/>
                              <check_value value="event.param2.macro.ismacro.[macro.constellation_andromeda_macro,macro.mole_macro,macro.redeemer_macro,
                                                                                macro.retaliator_macro,macro.spirit_a1_macro,macro.spirit_c1_macro,
                                                                                ]"/>
                              <check_value value="$hasship_s"/>
                         </conditions>
                         <actions>
                              <remove_docking_request ship="event.param2" container="event.param" immediate="true"/>
                              <do_for_each name="$order" in="event.param2.orders">
                                   <do_if value="$order.id == 'DockAt'">
                                        <cancel_order order="$order" />
                                   </do_if>
                              </do_for_each>
                         </actions>
                    </cue>

                    <cue name="kraken_logical_dock_05" instantiate="true">
                         <conditions>
                              <event_object_dock_assigned_at group="$Object_kraken"/>
                              <check_value value="event.param2.isclass.[class.ship_m]"/>
                              <check_value value="not event.param2.macro.ismacro.[macro.constellation_andromeda_macro,macro.mole_macro,macro.redeemer_macro,
                                                                                macro.retaliator_macro,macro.spirit_a1_macro,macro.spirit_c1_macro,
                                                                                ]"/>
                         </conditions>
                         <actions>
                              <remove_docking_request ship="event.param2" container="event.param" immediate="true"/>
                              <do_for_each name="$order" in="event.param2.orders">
                                   <do_if value="$order.id == 'DockAt'">
                                        <cancel_order order="$order" />
                                   </do_if>
                              </do_for_each>
                         </actions>
                    </cue>

                    <cue name="kraken_logical_dock_06" instantiate="true">
                         <conditions>
                              <event_object_dock_assigned_at group="$Object_kraken"/>
                              <check_value value="event.param.macro.ismacro.[macro.kraken_airporta_macro,macro.kraken_airportb_macro,macro.dockingbay_aegs_bengal_m_macro]"/>
                              <check_value value="$hasship_m"/>
                         </conditions>
                         <actions>
                              <remove_docking_request ship="event.param2" container="event.param" immediate="true"/>
                              <do_for_each name="$order" in="event.param2.orders">
                                   <do_if value="$order.id == 'DockAt'">
                                        <cancel_order order="$order" />
                                   </do_if>
                              </do_for_each>
                         </actions>
                    </cue>
               </cues>
		</cue>
	</cues>
</mdscript>