<?xml version="1.0" encoding="utf-8"?>
<mdscript name="ship_system_test" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
	<cues>
          <cue name="ship_system_test01" instantiate="true">
               <conditions>
                    <check_any>
                         <event_game_loaded/>
                         <event_game_started/>
                    </check_any>
               </conditions>
			<actions>
                    
                    <create_ship name="$P2" sector="player.sector" macro="macro.retribution_macro">
                         <owner exact="faction.player"/>
                         <pilot>
                              <select tags="tag.pilot" race="race.terran"/>
                              <skills>
                                   <skill type="piloting"    exact="2"/>
                              </skills>
                         </pilot>
                    </create_ship>
                    <add_equipment_mods object="player.ship">
                          <weapon ware="ware.mod_weapon_damage_01_mk1" macro="macro.weapon_atf_xl_battleship_01_mk1_macro"/>
                    </add_equipment_mods>
			</actions>
		</cue>
	</cues>
</mdscript>