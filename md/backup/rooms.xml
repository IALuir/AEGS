<?xml version="1.0" encoding="utf-8" ?>
<mdscript name="aegs_rooms" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<cues>
		<cue name="Init" version="3.5">
			<delay exact="2s"/>
			<actions>
				<set_value name="$Debug" exact="false"/>
				<set_value name="$X4CorridorMacro" exact="null"/>
				<set_value name="$X4RoomMacroBar" exact="null"/>
				<set_value name="$X4RoomMacroBar2" exact="null"/>
				<set_value name="$X4RoomMacroCrewquarters" exact="null"/>
				<set_value name="$X4RoomMacroOffice" exact="null"/>
				<set_value name="$X4RoomMacroSecurity" exact="null"/>
				<set_value name="$X4RoomMacroTraffic" exact="null"/>
				<set_value name="$X4RoomMacroWarRoom" exact="null"/>
				<set_value name="$X4RoomMacroEmbassy" exact="null"/>
				<set_value name="$X4RoomMacroServerRoom" exact="null"/>
				<set_value name="$X4RoomMacroServiceRoom" exact="null"/>
				<set_value name="$X4RoomMacroGeneratorRoom" exact="null"/>
				<set_value name="$X4RoomMacroIntelOffice" exact="null"/>
				<set_value name="$X4RoomMacroCasino" exact="null"/>
				<set_value name="$Station" exact="player.station"/>
				<set_value name="$PlayerShip" exact="player.ship"/>
				<set_value name="$X4InteriorBar" exact="null"/>
				<set_value name="$X4InteriorBar2" exact="null"/>
				<set_value name="$X4InteriorCrewquarters" exact="null"/>
				<set_value name="$X4InteriorInfrastructure" exact="null"/>
				<set_value name="$X4InteriorOffice" exact="null"/>
				<set_value name="$X4InteriorSecurity" exact="null"/>
				<set_value name="$X4InteriorTraffic" exact="null"/>
				<set_value name="$X4InteriorWarRoom" exact="null"/>
				<set_value name="$X4InteriorEmbassy" exact="null"/>
				<set_value name="$X4InteriorLivingroom" exact="null"/>
				<set_value name="$X4InteriorServerRoom" exact="null"/>
				<set_value name="$X4InteriorServiceRoom" exact="null"/>
				<set_value name="$X4InteriorGeneratorRoom" exact="null"/>
				<set_value name="$X4InteriorIntelOffice" exact="null"/>
				<set_value name="$X4InteriorCasino" exact="null"/>
				<set_value name="$X4InteriorPlayerOffice" exact="null"/>
				<set_value name="$Corridor" exact="null"/>
				<set_value name="$Room" exact="null"/>
				<set_value name="$MainHQ" exact="md.X4Ep1_Mentor_Subscriptions.Start.$HQ"/>
				<set_value name="$ShadyGuyBar" exact="null"/>
				<get_room_definition macro="$X4CorridorMacro" tags="tag.corridor"/>
				<get_room_definition macro="$X4RoomMacroBar" tags="tag.bar"/>
				<get_room_definition macro="$X4RoomMacroBar2" tags="tag.bar2"/>
				<get_room_definition macro="$X4RoomMacroCrewquarters" tags="tag.crewquarters"/>
				<get_room_definition macro="$X4RoomMacroOffice" tags="tag.office"/>
				<get_room_definition macro="$X4RoomMacroSecurity" tags="tag.security"/>
				<get_room_definition macro="$X4RoomMacroTraffic" tags="tag.trafficcontrol"/>
				<get_room_definition macro="$X4RoomMacroWarRoom" tags="tag.warroom"/>
				<get_room_definition macro="$X4RoomMacroEmbassy" tags="tag.embassy"/>
				<get_room_definition macro="$X4RoomMacroLivingroom" tags="tag.livingroom"/>
				<get_room_definition macro="$X4RoomMacroServerRoom" tags="tag.serverroom"/>
				<get_room_definition macro="$X4RoomMacroServiceRoom" tags="tag.serviceroom"/>
				<get_room_definition macro="$X4RoomMacroGeneratorRoom" tags="tag.generatorroom"/>
				<get_room_definition macro="$X4RoomMacroIntelOffice" tags="tag.intelligenceoffice"/>
				<get_room_definition macro="$X4RoomMacroCasino" tags="tag.casino"/>
				<get_room_definition macro="$X4RoomMacroPlayerOffice" tags="tag.playeroffice"/>
				<get_room_definition macro="$X4RoomMacroInfrastructure" tags="tag.infrastructure"/>
				<set_value name="$StationTable" exact="null"/>
				<set_value name="$StationInteriorBar" exact="null"/>
				<set_value name="$StationInteriorBar2" exact="null"/>
				<set_value name="$StationInteriorCrewquarters" exact="null"/>
				<set_value name="$StationInteriorOffice" exact="null"/>
				<set_value name="$StationInteriorSecurity" exact="null"/>
				<set_value name="$StationInteriorCasino" exact="null"/>
				<set_value name="$StationInteriorPlayerOffice" exact="null"/>
				<set_value name="$StationInteriorInfrastructure" exact="null"/>
				<signal_cue_instantly cue="Check_Player"/>
			</actions>
			<patch sinceversion="3">
				<reset_cue cue="this"/>
			</patch>
			<cues>
				<cue name="Remove_X4Interior" instantiate="true">
					<conditions>
						<event_cue_signalled/>
					</conditions>
					<actions>
						<set_value name="$Obj" exact="event.param.{1}"/>
						<set_value name="$Interior" exact="event.param.{2}"/>
						<remove_dynamic_interior object="$Obj" interior="$Interior"/>
						<destroy_object object="$Interior"/>
						<remove_value name="$Interior"/>
						<remove_value name="$Corridor"/>
						<remove_value name="$Room"/>
					</actions>
				</cue>
				<cue name="Setup_All" instantiate="true">
					<conditions>
						<check_any>
							<event_object_changed_object object="player.entity"/>
							<event_cue_signalled/>
						</check_any>
					</conditions>
					<actions>
						<set_value name="$Station" exact="null"/>
						<set_value name="$PlayerShip" exact="null"/>
						<set_value name="$Debug" exact="false"/>
						<set_value name="$MainHQ" exact="md.X4Ep1_Mentor_Subscriptions.Start.$HQ"/>
						<set_value name="$Station" exact="player.station"/>
						<set_value name="$PlayerShip" exact="player.ship"/>
						<set_value name="$X4Interior" exact="null"/>
						<set_value name="$Corridor" exact="null"/>
						<set_value name="$Room" exact="null"/>
		<!--get the correct corridor macro -->
						<debug_text text="'Getting the corridor macro'" chance="0" filter="general"/>
						<do_if value="$PlayerShip">
						    <debug_text text="'Corridor Macro:  in a Ship'" chance="0" filter="general"/>
						<!--Player Ship  !!!!!!!CHANGE THE RACE TO CHANGE HOW THE PLAYER SHIP ARE MADE!!!!!!-->
							<do_if value="$PlayerShip.trueowner == faction.player" exact="true">
								<get_room_definition macro="$X4CorridorMacro" race="race.argon" tags="tag.corridor"/>
							</do_if>
						<!--Split Ship -->
							<do_elseif value="$PlayerShip.trueowner.primaryrace == race.split">
								<get_room_definition macro="$X4CorridorMacro" race="race.split" tags="tag.corridor"/>
							</do_elseif>
						<!--Argon Ship -->
							<do_elseif value="$PlayerShip.trueowner.primaryrace == race.argon">
								<get_room_definition macro="$X4CorridorMacro" race="race.argon" tags="tag.corridor"/>
							</do_elseif>
						<!--Par Ship -->	
							<do_elseif value="$PlayerShip.trueowner.primaryrace == race.paranid">
								<get_room_definition macro="$X4CorridorMacro" race="race.paranid" tags="tag.corridor"/>
							</do_elseif>
						<!--Tel Ship -->	
							<do_elseif value="$PlayerShip.trueowner.primaryrace == race.teladi">
								<get_room_definition macro="$X4CorridorMacro" race="race.teladi" tags="tag.corridor"/>
							</do_elseif>
						<!--Terran Ship -->	
							<do_elseif value="$PlayerShip.trueowner.primaryrace == race.terran">
								<get_room_definition macro="$X4CorridorMacro" race="race.terran" tags="tag.corridor"/>
							</do_elseif>
						<!--Boron Ship -->	
							<do_elseif value="$PlayerShip.trueowner.primaryrace == race.boron">
								<get_room_definition macro="$X4CorridorMacro" race="race.boron" tags="tag.corridor"/>
							</do_elseif>
						</do_if>
						<signal_cue_instantly cue="Check_Player"/>
					</actions>
				</cue>
				<cue name="Check_Player" instantiate="true">
					<conditions>
						<check_any>
							<event_cue_signalled/>
						</check_any>
					</conditions>
					<actions>
						<do_if value="$PlayerShip">
		<!--if the ship is damaged severely, the captains quarters should be the damaged version -->
							<do_if value="$PlayerShip.hull le ($PlayerShip.maxhull * 0.2)">
								<get_room_definition macro="$X4RoomMacroLivingroom" tags="[tag.livingroom, tag.shady]"/>
							</do_if>
							<do_else>
								<get_room_definition macro="$X4RoomMacroLivingroom" tags="[tag.livingroom, tag.generic]"/>
							</do_else>
							<signal_cue_instantly cue="Place_Ship"/>
						</do_if>
						<do_else>
							<do_if value="$Station">
								<do_if value="$Station.hull le ($Station.maxhull * 0.2)">
									<get_room_definition macro="$X4RoomMacroLivingroom" tags="[tag.livingroom, tag.shady]"/>
								</do_if>
								<do_else>
									<get_room_definition macro="$X4RoomMacroLivingroom" tags="[tag.livingroom, tag.generic]"/>
								</do_else>
								<signal_cue_instantly cue="Place_Station"/>
							</do_if>
						</do_else>
					</actions>
				</cue>
				<cue name="Clean_Rooms" instantiate="true">
					<conditions>
						<event_cue_signalled/>
					</conditions>
					<actions>
						<do_if value="$StationInteriorInfrastructure">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorInfrastructure]"/>
						</do_if>
						<do_if value="$StationInteriorCasino">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorCasino]"/>
						</do_if>
						<do_if value="$StationInteriorPlayerOffice">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorPlayerOffice]"/>
						</do_if>
						<do_if value="$StationInteriorSecurity">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorSecurity]"/>
						</do_if>
						<do_if value="$StationInteriorTraffic">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorTraffic]"/>
						</do_if>
						<do_if value="$StationInteriorWarRoom">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorWarRoom]"/>
						</do_if>
						<do_if value="$StationInteriorServerRoom">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorServerRoom]"/>
						</do_if>
						<do_if value="$StationInteriorServiceRoom">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorServiceRoom]"/>
						</do_if>
						<do_if value="$StationInteriorLivingroom">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorLivingroom]"/>
						</do_if>
						<do_if value="$StationInteriorEmbassy">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorEmbassy]"/>
						</do_if>
						<do_if value="$StationInteriorGeneratorRoom">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorGeneratorRoom]"/>
						</do_if>
						<do_if value="$StationInteriorOffice">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorOffice]"/>
						</do_if>	
						<do_if value="$StationInteriorBar">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorBar]"/>
						</do_if>
						<do_if value="$StationInteriorBar2">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorBar2]"/>
						</do_if>
						<do_if value="$StationInteriorCrewquarters">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorCrewquarters]"/>
						</do_if>
						<do_if value="$StationInteriorIntelOffice">
							<signal_cue_instantly cue="Remove_X4Interior" param="[$StationTable, $StationInteriorIntelOffice]"/>
						</do_if>
					</actions>
				</cue>
				<cue name="Player_Taken_Control" instantiate="true">
					<conditions>
						<event_player_started_control/>
					</conditions>
					<actions>
						<signal_cue_instantly cue="Clean_Rooms"/>
					</actions>
				</cue>
				<cue name="Player_Relieved_Control" instantiate="true">
					<conditions>
						<event_player_stopped_control/>
					</conditions>
					<actions>
						<signal_cue_instantly cue="Setup_All"/>
					</actions>
				</cue>
				<cue name="Place_Ship" instantiate="true">
					<conditions>
						<event_cue_signalled/>
					</conditions>
					<actions>	
						<signal_cue_instantly cue="Clean_Rooms"/>
						<do_if value="$PlayerShip.trueowner == faction.player">
		<!-- Create X4Interior -->
							<do_if value="$PlayerShip.ismacro.{macro.ship_aegs_l_javelin_macro}">
									<create_dynamic_interior object="$PlayerShip" door="'con_room_01'" corridor="macro.room_arg_corridor_06_macro" room="$X4RoomMacroCrewquarters" name="readtext.{20037}.{4}" interiorname="$X4InteriorCrewquarters" corridorname="$Corridor" roomname="$Room" roomtype="roomtype.crewquarters"/>
							</do_if>
						</do_if>
		<!--if the ship is AI owned -->
						<do_else>
			<!-- Create X4Interior -->
							<do_if value="$PlayerShip.ismacro.{macro.ship_aegs_l_javelin_macro}">
									<create_dynamic_interior object="$PlayerShip" door="'con_room_01'" corridor="macro.room_arg_corridor_06_macro" room="$X4RoomMacroCrewquarters" name="readtext.{20037}.{4}" interiorname="$X4InteriorCrewquarters" corridorname="$Corridor" roomname="$Room" roomtype="roomtype.crewquarters"/>
			               </do_if>
						</do_else>
						<do_if value="$PlayerShip.ismacro.{macro.ship_aegs_l_javelin_macro}">
							<create_dynamic_interior object="$PlayerShip" door="'con_room_01'" corridor="macro.room_arg_corridor_04_macro" room="$X4RoomMacroLivingroom" name="readtext.{20037}.{11}" interiorname="$X4InteriorLivingroom" corridorname="$Corridor" roomname="$Room" roomtype="roomtype.livingroom" private="true"/>
						</do_if>
						<set_value name="$StationTable" exact="$PlayerShip"/>
						<set_value name="$StationInteriorBar" exact="$X4InteriorBar"/>
						<set_value name="$StationInteriorBar2" exact="$X4InteriorBar2"/>
						<set_value name="$StationInteriorCrewquarters" exact="$X4InteriorCrewquarters"/>
						<set_value name="$StationInteriorOffice" exact="$X4InteriorOffice"/>
						<set_value name="$StationInteriorSecurity" exact="$X4InteriorSecurity"/>
						<set_value name="$StationInteriorTraffic" exact="$X4InteriorTraffic"/>
						<set_value name="$StationInteriorWarRoom" exact="$X4InteriorWarRoom"/>
						<set_value name="$StationInteriorServerRoom" exact="$X4InteriorServerRoom"/>
						<set_value name="$StationInteriorServiceRoom" exact="$X4InteriorServiceRoom"/>
						<set_value name="$StationInteriorLivingroom" exact="$X4InteriorLivingroom"/>
						<set_value name="$StationInteriorEmbassy" exact="$X4InteriorEmbassy"/>
						<set_value name="$StationInteriorIntelOffice" exact="$X4InteriorIntelOffice"/>
						<set_value name="$StationInteriorGeneratorRoom" exact="$X4InteriorGeneratorRoom"/>
						<set_value name="$StationInteriorCasino" exact="$X4InteriorCasino"/>
						<set_value name="$StationInteriorPlayerOffice" exact="$X4InteriorPlayerOffice"/>
						<set_value name="$StationInteriorInfrastructure" exact="$X4InteriorInfrastructure"/>
						<set_value name="$X4InteriorBar" exact="null"/>
						<set_value name="$X4InteriorBar2" exact="null"/>
						<set_value name="$X4InteriorCrewquarters" exact="null"/>
						<set_value name="$X4InteriorOffice" exact="null"/>
						<set_value name="$X4InteriorSecurity" exact="null"/>
						<set_value name="$X4InteriorTraffic" exact="null"/>
						<set_value name="$X4InteriorWarRoom" exact="null"/>
						<set_value name="$X4InteriorIntelOffice" exact="null"/>
						<set_value name="$X4InteriorServerRoom" exact="null"/>
						<set_value name="$X4InteriorServiceRoom" exact="null"/>
						<set_value name="$X4InteriorLivingroom" exact="null"/>
						<set_value name="$X4InteriorEmbassy" exact="null"/>
						<set_value name="$X4InteriorGeneratorRoom" exact="null"/>
						<set_value name="$X4InteriorCasino" exact="null"/>
						<set_value name="$X4InteriorPlayerOffice" exact="null"/>
						<set_value name="$X4InteriorInfrastructure" exact="null"/>
					</actions>
				</cue>
			</cues>
		</cue>
	</cues>
</mdscript>