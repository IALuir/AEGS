<?xml version="1.0" encoding="utf-8"?>
<mdscript name="constellation_andromeda_p52" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
	<cues>
          <cue name="Player_constellation_andromeda_p52_Build_Finished" instantiate="true">
               <conditions>
                    <event_player_build_finished/>
                    <check_value value="@event.param3.buildobject.macro.ismacro.{macro.constellation_andromeda_macro} or @event.param3.macro.ismacro.{macro.constellation_andromeda_macro}"/>
               </conditions>
               <actions>
                    <set_value name="$Ship" exact="@event.param3.buildobject"/>

                    <create_ship name="$P52" dock="$Ship" macro="macro.p52_merlin_macro">
                         <owner exact="faction.player"/>
                         <pilot>
                              <select tags="tag.pilot" race="race.terran"/>
                              <skills>
                                   <skill type="piloting"    exact="2"/>
                              </skills>
                         </pilot>
                    </create_ship>
               </actions>
          </cue>

          <cue name="constellation_andromeda_dock_01" instantiate="true">
			<conditions>
                    <check_any>
					<event_game_started />
					<event_game_loaded />
				</check_any>
               </conditions>
			<actions>
				<create_group groupname="$Object_constellation"/>
			</actions>
               <cues>
                    <cue name="constellation_andromeda_dock_02" instantiate="true" checkinterval="3s">
                         <actions>
                              <find_ship name="$Object" macro="macro.constellation_andromeda_macro"  multiple="true" />
                              <do_for_each name="$ship" in="$Object">
                                   <add_to_group groupname="$Object_constellation" object="$ship"/>
				          </do_for_each>
                         </actions>
                    </cue>

                    <cue name="constellation_andromeda_dock_03" instantiate="true" checkinterval="5s">
                         <actions>
                              <clear_group group="$Object_constellation"/>
                         </actions>
                    </cue>

                    <cue name="constellation_andromeda_dock_04" instantiate="true">
                         <conditions>
                              <event_object_dock_assigned_at group="$Object_constellation"/>
                              <check_value value="not event.param2.macro.ismacro.[macro.p52_merlin_macro]"/>
                         </conditions>
                         <actions>
                              <remove_docking_request ship="event.param2" container="event.param" immediate="true"/>
                              <do_for_each name="$order" in="event.param2.orders">
                                   <do_if value="$order.id == 'DockAt'">
                                        <cancel_order order="$order" />
                                   </do_if>
                        	     </do_for_each>
                         </actions>
                    </cue>
               </cues>
		</cue>
	</cues>
</mdscript>