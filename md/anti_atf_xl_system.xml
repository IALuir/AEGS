<?xml version="1.0" encoding="utf-8"?>
<mdscript name="anti_atf_xl_system" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
	<cues>
          <cue name="anti_atf_xl_systems_01" instantiate="true">
               <conditions>
                    <check_any>
                         <event_game_loaded/>
                         <event_game_started/>
                    </check_any>
               </conditions>
			<actions>
                    <do_if value="$Object_ShipGroup">
                         <clear_group group="$Object_ShipGroup"/>
                    </do_if>
                    <do_else>
                         <create_group groupname="$Object_ShipGroup"/>
                    </do_else>
			</actions>
               <cues>
                    <cue name="anti_atf_xl_system_02" instantiate="true" checkinterval="10s">
                         <actions>
                              <find_ship name="$Object_Ship" macro="macro.retribution_macro"  multiple="true" />
                              <do_for_each name="$ship" in="$Object_Ship">
                                   <add_to_group groupname="$Object_ShipGroup" object="$ship"/>
                              </do_for_each>
                         </actions>
                    </cue>
                    <cue name="anti_atf_xl_system_03" instantiate="true">
                         <conditions>
                              <check_any>
                                   <event_object_hull_damaged group="$Object_ShipGroup"/>
                                   <event_object_shield_damaged group="$Object_ShipGroup"/>
                              </check_any>
                         </conditions>
                         <actions>
                              <do_if value="@event.name == 'event_object_hull_damaged'">
                                   <do_if value="@event.param.lastattacker.macro == macro.ship_atf_xl_battleship_01_a_macro">
                                        <do_if value="@event.param3 gt 32700">
                                             <set_value name="$damage_hull_per"  exact="@event.param3/@event.param.maxhull * 100 * 0.8"/>
                                             <set_object_hull object="@event.param" exact="@event.param.hullpercentage + $damage_hull_per"/>
                                        </do_if>
                                   </do_if>
                                   <do_if value="@event.param.lastattacker.macro == macro.ship_kha_xl_battleship_01_a_macro">
                                        <do_if value="@event.param3 gt 90000">
                                             <set_value name="$damage_hull_per"  exact="@event.param3/@event.param.maxhull * 100 * 0.9"/>
                                             <set_object_hull object="@event.param" exact="@event.param.hullpercentage + $damage_hull_per"/>
                                        </do_if>
                                   </do_if>
                                   <do_if value="@event.param.lastattacker.macro == macro.ship_kha_l_destroyer_01_a_macro">
                                        <do_if value="@event.param3 gt 9000">
                                             <set_value name="$damage_hull_per"  exact="@event.param3/@event.param.maxhull * 100 * 0.2"/>
                                             <set_object_hull object="@event.param" exact="@event.param.hullpercentage + $damage_hull_per"/>
                                        </do_if>
                                   </do_if>
                              </do_if>
                              <do_else>
                                   <do_if value="@event.param.lastattacker.macro == macro.ship_atf_xl_battleship_01_a_macro">
                                        <do_if value="@event.param3 gt 33042">
                                             <set_value name="$damage_shield_per"  exact="@event.param3/@event.param.maxshield * 100 * 0.8"/>
                                             <set_object_shield object="@event.param" exact="@event.param.shieldpercentage + $damage_shield_per"/>
                                        </do_if>
                                   </do_if>
                                   <do_if value="@event.param.lastattacker.macro == macro.ship_kha_xl_battleship_01_a_macro">
                                        <do_if value="@event.param3 gt 90000">
                                             <set_value name="$damage_shield_per"  exact="@event.param3/@event.param.maxshield * 100 * 0.9"/>
                                             <set_object_shield object="@event.param" exact="@event.param.shieldpercentage + $damage_shield_per"/>
                                        </do_if>
                                   </do_if>
                                   <do_if value="@event.param.lastattacker.macro == macro.ship_kha_l_destroyer_01_a_macro">
                                        <do_if value="@event.param3 gt 9000">
                                             <set_value name="$damage_shield_per"  exact="@event.param3/@event.param.maxshield * 100 * 0.2"/>
                                             <set_object_shield object="@event.param" exact="@event.param.shieldpercentage + $damage_shield_per"/>
                                        </do_if>
                                   </do_if>
                              </do_else>
                         </actions>
                    </cue>
                    <cue name="InterestingObject_Destroyed" instantiate="true">
                         <conditions>
                              <event_object_destroyed group="$Object_ShipGroup"/>
                         </conditions>
                         <actions>
                              <remove_from_group group="$Object_ShipGroup" object="event.object"/>
                         </actions>
                    </cue>
               </cues>
		</cue>
	</cues>
</mdscript>