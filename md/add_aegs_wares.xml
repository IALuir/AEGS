<?xml version="1.0" encoding="utf-8" ?>
<mdscript name="Addthemestoplayer" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
    <cues>
        <cue name="add_aegs_wares">
            <conditions>
                <check_any>
                    <event_game_started />
                    <event_game_loaded />
                </check_any>
            </conditions>
            <delay exact="5s" />
            <actions>
                <set_value name="$aegswares" exact="[
                ware.engine_aegs_max_javelin_macro,
                ware.engine_f8c_lightning_macro,
                ware.engine_aegs_xl_bengal,
                ware.hammerhead_engine,
                ware.retaliator_engine,
                ware.scorpius_engine,
                ware.engine_kraken_engine,
                ware.engine_idris_engine,
                ware.arrow_engine,
                ware.eclipse_engine,
                ware.starlifter_engine,
                ware.f7a_engine,
                ware.f7c_engine,
                ware.starfighter_engine,
                ware.talon_engine,
                ware.sabre_engine,
                ware.gladius_engine,
                ware.vanguard_engine,
                ware.cutlass_engine,
                ware.retribution_engine,
                ware.constellation_andromeda_engine,
                ware.p52_merlin_engine,
                ware.reclaimer_engine,
                ware.wepon_missile_s12,
                ware.wepon_missile_s12_s11,
                ware.wepon_missile_s11,
                ware.wepon_missile_s10,
                ware.wepon_missile_s9,
                ware.wepon_missile_s9_s8,
                ware.wepon_missile_s8,
                ware.wepon_missile_s7,
                ware.wepon_missile_s6,
                ware.wepon_missile_s5,
                ware.wepon_missile_s4,
                ware.wepon_missile_s4_s3,
                ware.wepon_missile_s3,
                ware.wepon_missile_s3_s2,
                ware.wepon_missile_s2,
                ware.wepon_missile_s2_s1,
                ware.wepon_f8_s2_missile,
                ware.wepon_f8_s1_missile,
                ware.weapon_left_hammerhead_s3_missile,
                ware.weapon_rigth_hammerhead_s3_missile,
                ware.weapon_vanguard_s2,
                ware.weapon_p52_s3,
                ware.generic_s2_missile,
                ware.generic_s1_missile,
                ware.avenger_engine,
                ware.spirit_a1_engine,
                ware.redeemer_engine,
                ware.mole_engine,
                ware.polaris_engine,
                ware.prospector_engine
                ]" />
                <!-- passing the list to add_blueprints -->
                <add_blueprints wares="$aegswares" />
                <!-- explicit cleanup -->
                <remove_value name="$aegswares" />
            </actions>
        </cue>

        <cue name="update_aegs_cf_s2_wares" instantiate="true" checkinterval="5s">
            <conditions>
                <check_value value="player.blueprints.{ware.weapon_cf_s2}.any.exists"/>
            </conditions>
            <actions>
                <set_value name="$updateaegswarescf2" exact="[
                ware.turret_arrow_s2_cf,
                ware.cutlass_turret_s2_cf,
                ware.turret_f7cm_s2_cf,
                ware.cutlass_turret_s2_cf,
                constellation_andromeda_turret_cf]" />
                <add_blueprints wares="$updateaegswarescf2" />
                <remove_value name="$updateaegswarescf2" />
            </actions>
        </cue>

        <cue name="update_aegs_mxa_s2_wares" instantiate="true" checkinterval="5s">
